---
export interface Props {
    page?: string;
}
const { page } = Astro.props;
---
<nav>
    <div class="links">
        <a href="/" class={page === 'index' ? 'active' : ''}>Home</a>
        <a href="/blog" class={page === 'blog' || page === 'blogPost' ? 'active' : ''}>Blog</a>
        <a href="/resume.pdf" target="_blank" rel="noopener">Resume</a>
    </div>
</nav>
<style>
    nav {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1.25rem 2rem;
        border-bottom: 1px solid var(--border);
    }
    .links {
        display: flex;
        gap: 2rem;
        align-items: center;
    }
    .links a {
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--fg);
        border-bottom: 1px solid transparent;
        padding-bottom: 2px;
        transition: border-color 0.15s;
    }
    .links a:hover,
    .links a.active {
        border-color: var(--fg);
    }
</style>
