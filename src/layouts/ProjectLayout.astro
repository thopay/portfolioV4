---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
const {frontmatter} = Astro.props;
---
<Layout title={frontmatter.title} description={frontmatter.description} image={"https://thopay.dev" + frontmatter.image}>
    <Nav page="project"/>
    <main>
        <article>
            <header>
                <a href="/projects" class="back">← All projects</a>
                <h1>{frontmatter.title}</h1>
                <div class="meta">
                    <time>{frontmatter.date}</time>
                    {frontmatter.link && (
                        <a href={frontmatter.link} target="_blank" rel="noopener" class="ext-link">View Project ↗</a>
                    )}
                </div>
            </header>
            <div class="content">
                <slot />
            </div>
        </article>
    </main>
</Layout>

<style>
    main {
        padding: 3rem 2rem;
    }
    article {
        max-width: 800px;
        margin: 0 auto;
    }
    header {
        margin-bottom: 3rem;
        padding-bottom: 2rem;
        border-bottom: 1px solid var(--border);
    }
    .back {
        display: inline-block;
        font-size: 0.875rem;
        color: var(--fg-muted);
        margin-bottom: 1.5rem;
        transition: color 0.15s;
    }
    .back:hover {
        color: var(--fg);
    }
    h1 {
        font-size: clamp(1.5rem, 3vw, 2rem);
        font-weight: 600;
        letter-spacing: -0.02em;
        line-height: 1.2;
        margin: 0 0 0.75rem;
    }
    .meta {
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }
    time {
        font-size: 0.875rem;
        color: var(--fg-muted);
    }
    .ext-link {
        font-size: 0.875rem;
        color: var(--fg-muted);
        transition: color 0.15s;
    }
    .ext-link:hover {
        color: var(--fg);
    }

    /* Markdown content */
    :global(.content h1),
    :global(.content h2),
    :global(.content h3),
    :global(.content h4),
    :global(.content h5),
    :global(.content h6) {
        color: var(--fg);
        font-weight: 600;
        line-height: 1.3;
        margin: 2em 0 0.75em;
        letter-spacing: -0.01em;
    }
    :global(.content h1) { font-size: 1.625rem; }
    :global(.content h2) { font-size: 1.25rem; }
    :global(.content h3) { font-size: 1.0625rem; }
    :global(.content h4),
    :global(.content h5),
    :global(.content h6) { font-size: 1rem; }

    :global(.content p) {
        color: var(--fg);
        font-size: 1rem;
        line-height: 1.75;
        font-weight: 300;
        margin: 0 0 1.25em;
    }
    :global(.content a) {
        color: var(--fg);
        text-decoration: underline;
        text-underline-offset: 3px;
        text-decoration-color: var(--border);
        transition: text-decoration-color 0.15s;
    }
    :global(.content a:hover) {
        text-decoration-color: var(--fg);
    }
    :global(.content ul),
    :global(.content ol) {
        color: var(--fg);
        font-size: 1rem;
        font-weight: 300;
        line-height: 1.75;
        margin: 0 0 1.25em;
        padding-left: 1.5em;
    }
    :global(.content li) {
        margin-bottom: 0.4em;
    }
    :global(.content blockquote) {
        border-left: 2px solid var(--fg-muted);
        padding-left: 1.25em;
        margin: 1.5em 0;
        color: var(--fg-muted);
        font-style: italic;
    }
    :global(.content pre) {
        background: transparent;
        border: 1px solid var(--border);
        border-radius: 4px;
        padding: 1em 1.25em;
        overflow-x: auto;
        font-size: 0.875rem;
        line-height: 1.6;
        margin: 1.5em 0;
    }
    :global(.content code) {
        font-size: 0.875em;
        font-family: 'Fira Code', 'Cascadia Code', 'JetBrains Mono', ui-monospace, monospace;
    }
    :global(.content p code),
    :global(.content li code) {
        background: var(--border);
        padding: 0.15em 0.4em;
        border-radius: 3px;
    }
    :global(.content strong) {
        font-weight: 600;
    }
    :global(.content hr) {
        border: none;
        border-top: 1px solid var(--border);
        margin: 2.5em 0;
    }
    :global(.content img) {
        width: 100%;
        height: auto;
        margin: 1.5em 0;
        border-radius: 4px;
        display: block;
    }
    :global(.content table) {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.9rem;
        margin: 1.5em 0;
    }
    :global(.content table th) {
        color: var(--fg);
        font-weight: 600;
        text-align: left;
        padding: 0.5em 0.75em;
        border-bottom: 1px solid var(--border);
    }
    :global(.content table td) {
        color: var(--fg);
        font-weight: 300;
        padding: 0.5em 0.75em;
        border-bottom: 1px solid var(--border);
    }
    :global(.content table tr:last-child td) {
        border-bottom: none;
    }
</style>
