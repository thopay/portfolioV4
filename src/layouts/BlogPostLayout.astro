---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
const {frontmatter} = Astro.props;
---
<Layout title={frontmatter.title} description={frontmatter.description}>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.15.1/dist/katex.css" integrity="sha384-WsHMgfkABRyG494OmuiNmkAOk8nhO1qE+Y6wns6v+EoNoTNxrWxYpl5ZYWFOLPCM" crossorigin="anonymous">
    <Nav page="blogPost"/>
    <main transition:name="page-content">
        <article>
            <header>
                <a href="/blog" class="back">← All posts</a>
                <h1>{frontmatter.title}</h1>
                <time>{frontmatter.date}</time>
            </header>
            <div class="content">
                <slot />
            </div>
        </article>
    </main>
</Layout>

<style>
    main {
        padding: 3rem 2rem;
    }
    article {
        max-width: 640px;
        margin: 0 auto;
    }
    header {
        margin-bottom: 3rem;
        padding-bottom: 2rem;
        border-bottom: 1px solid var(--border);
    }
    .back {
        display: inline-block;
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--fg);
        border-bottom: 1px solid var(--border);
        padding-bottom: 2px;
        margin-bottom: 1.5rem;
        transition: border-color 0.15s;
    }
    .back:hover {
        border-color: var(--fg);
    }
    h1 {
        font-size: clamp(1.5rem, 3vw, 2rem);
        font-weight: 600;
        letter-spacing: -0.02em;
        line-height: 1.2;
        margin: 0 0 0.75rem;
    }
    time {
        font-size: 0.875rem;
        color: var(--fg-muted);
    }

    /* Markdown content styles */
    :global(.content h1),
    :global(.content h2),
    :global(.content h3),
    :global(.content h4),
    :global(.content h5),
    :global(.content h6) {
        color: var(--fg);
        font-weight: 600;
        line-height: 1.3;
        margin: 2.25em 0 0.75em;
        letter-spacing: -0.01em;
    }
    :global(.content > :first-child) {
        margin-top: 0;
    }
    :global(.content h1) { font-size: 1.625rem; }
    :global(.content h2) { font-size: 1.25rem; }
    :global(.content h3) { font-size: 1.0625rem; }
    :global(.content h4),
    :global(.content h5),
    :global(.content h6) { font-size: 1rem; }

    :global(.content p) {
        color: var(--fg);
        font-size: 1rem;
        line-height: 1.8;
        font-weight: 300;
        margin: 0 0 1.5em;
    }

    /* References / footnote section */
    :global(.content h3:last-of-type ~ p),
    :global(.content h4:last-of-type ~ p) {
        font-size: 0.875rem;
        color: var(--fg-muted);
        line-height: 1.6;
    }
    :global(.content a) {
        color: var(--fg);
        text-decoration: underline;
        text-underline-offset: 3px;
        text-decoration-color: var(--border);
        transition: text-decoration-color 0.15s;
    }
    :global(.content a:hover) {
        text-decoration-color: var(--fg);
    }
    :global(.content ul),
    :global(.content ol) {
        color: var(--fg);
        font-size: 1rem;
        font-weight: 300;
        line-height: 1.75;
        margin: 0 0 1.25em;
        padding-left: 1.5em;
    }
    :global(.content li) {
        margin-bottom: 0.4em;
    }
    :global(.content blockquote) {
        border-left: 2px solid var(--fg-muted);
        padding-left: 1.25em;
        margin: 1.5em 0;
        color: var(--fg-muted);
        font-style: italic;
    }
    :global(.content pre) {
        background: transparent;
        border: 1px solid var(--border);
        border-radius: 4px;
        padding: 1em 1.25em;
        overflow-x: auto;
        font-size: 0.875rem;
        line-height: 1.6;
        margin: 1.5em 0;
    }
    :global(.content code) {
        font-size: 0.875em;
        font-family: 'Fira Code', 'Cascadia Code', 'JetBrains Mono', ui-monospace, monospace;
    }
    :global(.content p code),
    :global(.content li code) {
        background: var(--border);
        padding: 0.15em 0.4em;
        border-radius: 3px;
    }
    :global(.content strong) {
        font-weight: 600;
    }
    :global(.content hr) {
        border: none;
        border-top: 1px solid var(--border);
        margin: 2.5em 0;
    }
    :global(.content img) {
        width: 100%;
        max-width: 100%;
        height: auto;
        margin: 1.5em 0;
        border-radius: 4px;
    }
    :global(.content table) {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.9rem;
        margin: 1.5em 0;
    }
    :global(.content table th) {
        color: var(--fg);
        font-weight: 600;
        text-align: left;
        padding: 0.5em 0.75em;
        border-bottom: 1px solid var(--border);
    }
    :global(.content table td) {
        color: var(--fg);
        font-weight: 300;
        padding: 0.5em 0.75em;
        border-bottom: 1px solid var(--border);
    }
    :global(.content table tr:last-child td) {
        border-bottom: none;
    }
</style>
