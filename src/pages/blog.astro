---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
const allPosts = await Astro.glob('./blog/*.md');
const sorted = allPosts.sort(
    (a, b) => new Date(b.frontmatter.date).valueOf() - new Date(a.frontmatter.date).valueOf()
);
---

<Layout title="Thomas — Blog" description="Writing on software engineering, design, and technology by Thomas.">
    <Nav page="blog" />
    <main transition:name="page-content">
        <div class="container">
<ul class="posts">
                {sorted.map(post => (
                    <li>
                        <a href={post.url} class="post-link">
                            <span class="post-title">{post.frontmatter.title}</span>
                            <span class="post-date">{post.frontmatter.date}</span>
                        </a>
                        {post.frontmatter.description && (
                            <p class="post-desc">{post.frontmatter.description}</p>
                        )}
                    </li>
                ))}
            </ul>
        </div>
    </main>
</Layout>

<style>
    main {
        padding: 3rem 2rem;
    }
    .container {
        max-width: 640px;
        margin: 0 auto;
    }
    h1 {
        font-size: 1.375rem;
        font-weight: 600;
        margin: 0 0 2.5rem;
        letter-spacing: -0.02em;
    }
    .posts {
        list-style: none;
        padding: 0;
        margin: 0;
    }
    li {
        padding: 1.375rem 0;
        border-top: 1px solid var(--border);
    }
    li:last-child {
        border-bottom: 1px solid var(--border);
    }
    .post-link {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 1rem;
        margin-bottom: 0.375rem;
    }
    .post-title {
        font-size: 0.9375rem;
        font-weight: 500;
        transition: color 0.15s;
    }
    .post-link:hover .post-title {
        color: var(--fg-muted);
    }
    .post-date {
        font-size: 0.8125rem;
        color: var(--fg-muted);
        white-space: nowrap;
        flex-shrink: 0;
    }
    .post-desc {
        font-size: 0.875rem;
        color: var(--fg-muted);
        margin: 0;
        line-height: 1.6;
        font-weight: 300;
    }
</style>
