---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
---

<Layout title="Thomas — Software Engineer" description="Thomas is a software engineer at Splunk focused on frontend development. Iowa State University, B.S. Software Engineering, 2025.">
<main>
        <section class="hero">
            <div class="hero-inner">
                <p class="bio">
                    Hi, I'm <span class="name">Thomas</span>. I'm a software engineer at Splunk with a focus on frontend development.
                    I graduated from Iowa State University in 2025 with a degree in Software Engineering.
                    Outside of work, I'm usually reading, traveling, or at a music festival.
                </p>
                <div class="links">
                    <a href="/blog">Blog</a>
                    <a href="https://github.com/thopay" target="_blank" rel="noopener">GitHub</a>
                    <a href="https://linkedin.com/in/thopay" target="_blank" rel="noopener">LinkedIn</a>
                    <a href="mailto:me@thopay.dev">Email</a>
                    <a href="/resume.pdf" target="_blank" rel="noopener">Resume</a>
                </div>

                <div class="timeline-section">
                    <div class="timeline">

                        <div class="timeline-item current">
                            <div class="timeline-dot"></div>
                            <div class="timeline-content">
                                <div class="timeline-header">
                                    <span class="timeline-company">
                                        <img src="https://www.google.com/s2/favicons?domain=splunk.com&sz=128" alt="Splunk" class="company-logo" />
                                        Splunk
                                    </span>
                                    <span class="timeline-date">Jun 2025 – Present</span>
                                </div>
                                <span class="timeline-role">Software Engineer · Chicago, IL</span>
                            </div>
                        </div>

                        <div class="timeline-item">
                            <div class="timeline-dot"></div>
                            <div class="timeline-content">
                                <div class="timeline-header">
                                    <span class="timeline-company">
                                        <img src="https://www.google.com/s2/favicons?domain=splunk.com&sz=128" alt="Splunk" class="company-logo" />
                                        Splunk
                                    </span>
                                    <span class="timeline-date">May – Aug 2024</span>
                                </div>
                                <span class="timeline-role">Software Engineer Intern · Boulder, CO</span>
                            </div>
                        </div>

                        <div class="timeline-item">
                            <div class="timeline-dot"></div>
                            <div class="timeline-content">
                                <div class="timeline-header">
                                    <span class="timeline-company">
                                        <img src="/deere-logo.svg" alt="John Deere" class="company-logo" />
                                        John Deere
                                    </span>
                                    <span class="timeline-date">May – Aug 2023</span>
                                </div>
                                <span class="timeline-role">Software Engineer Intern · Moline, IL</span>
                            </div>
                        </div>

                        <div class="timeline-item">
                            <div class="timeline-dot"></div>
                            <div class="timeline-content">
                                <div class="timeline-header">
                                    <span class="timeline-company">
                                        <img src="https://www.google.com/s2/favicons?domain=peachpay.app&sz=128" alt="PeachPay" class="company-logo peachpay-logo" />
                                        PeachPay
                                    </span>
                                    <span class="timeline-date">Jan – Aug 2022</span>
                                </div>
                                <span class="timeline-role">Software Engineer Intern · Ames, IA</span>
                            </div>
                        </div>

                        <div class="timeline-item">
                            <div class="timeline-dot"></div>
                            <div class="timeline-content">
                                <div class="timeline-header">
                                    <span class="timeline-company">
                                        <img src="https://www.google.com/s2/favicons?domain=iastate.edu&sz=128" alt="Iowa State University" class="company-logo" />
                                        Iowa State University
                                    </span>
                                    <span class="timeline-date">Aug 2021 – May 2025</span>
                                </div>
                                <span class="timeline-role">B.S. Software Engineering, Minor in Cyber Security · GPA 3.75</span>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>

<style>
    main {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
    }
    .hero {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 4rem 2rem;
        text-align: center;
    }
    .hero-inner {
        max-width: 600px;
        width: 100%;
    }
    .name {
        color: var(--fg);
        font-weight: 600;
        letter-spacing: -0.02em;
    }
    .bio {
        font-size: 1.275rem;
        line-height: 1.75;
        color: var(--fg-muted);
        margin: 0 auto 2.5rem;
        font-weight: 300;
        max-width: 600px;
    }
    .links {
        display: flex;
        gap: 1.75rem;
        flex-wrap: wrap;
        justify-content: center;
    }
    .links a {
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--fg);
        border-bottom: 1px solid var(--border);
        padding-bottom: 2px;
        transition: border-color 0.15s, color 0.15s;
    }
    .links a:hover {
        border-color: var(--fg);
    }

    /* Timeline */
    .timeline-section {
        margin-top: 3rem;
        padding-top: 2.5rem;
        border-top: 1px solid var(--border);
        text-align: left;
    }
    .timeline {
        position: relative;
        padding-left: 1.25rem;
    }
    .timeline::before {
        content: '';
        position: absolute;
        left: 3px;
        top: 8px;
        bottom: 8px;
        width: 1px;
        background: var(--border);
    }
    .timeline-item {
        position: relative;
        padding-bottom: 1.625rem;
    }
    .timeline-item:last-child {
        padding-bottom: 0;
    }
    .timeline-dot {
        position: absolute;
        left: -1.25rem;
        top: 7px;
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--border);
        border: 1px solid var(--border);
    }
    .timeline-item.current .timeline-dot {
        background: var(--fg);
        border-color: var(--fg);
    }
    .timeline-header {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 1rem;
        margin-bottom: 0.2rem;
    }
    .timeline-company {
        font-size: 0.9375rem;
        font-weight: 500;
        color: var(--fg);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .company-logo {
        width: 24px;
        height: 24px;
        border-radius: 4px;
        object-fit: contain;
        flex-shrink: 0;
    }
    .peachpay-logo {
        background: #fff;
        padding: 2px;
    }
    .timeline-date {
        font-size: 0.8125rem;
        color: var(--fg-muted);
        white-space: nowrap;
        flex-shrink: 0;
    }
    .timeline-role {
        font-size: 0.875rem;
        color: var(--fg-muted);
        font-weight: 300;
    }
</style>
