---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
---

<Layout title="404 — Page Not Found">
    <Nav />
    <main>
        <div class="container">
            <p class="code">404</p>
            <p class="message">This page doesn't exist.</p>
            <a href="/">Go home</a>
        </div>
    </main>
</Layout>

<style>
    main {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: calc(100vh - 65px);
        padding: 2rem;
    }
    .container {
        text-align: center;
    }
    .code {
        font-size: 5rem;
        font-weight: 600;
        letter-spacing: -0.04em;
        margin: 0 0 0.25rem;
        line-height: 1;
    }
    .message {
        font-size: 1rem;
        color: var(--fg-muted);
        font-weight: 300;
        margin: 0 0 2rem;
    }
    a {
        font-size: 0.875rem;
        font-weight: 500;
        border-bottom: 1px solid var(--border);
        padding-bottom: 2px;
        transition: border-color 0.15s;
    }
    a:hover {
        border-color: var(--fg);
    }
</style>
